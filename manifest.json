{
  "manifest_version": 3,
  "name": "简历自动填写助手（本地版）",
  "description": "本地保存多份简历资料，识别招聘网站或在线表单字段，一键智能填写。",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "简历自动填写助手",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "core.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
